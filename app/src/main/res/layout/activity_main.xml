<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="答题助手"
        android:textColor="#1565C0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="40dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="截屏识别题库 · 悬浮窗秒搜答案"
        android:textColor="#888888"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingBottom="24dp" />

    <!-- 题库统计卡片 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="本地题库"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvBankCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 道"
                android:textColor="#1565C0"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 导入截图按钮 -->
    <Button
        android:id="@+id/btnImport"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="导入截图 · 识别题库"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1565C0"
        android:layout_marginBottom="10dp"
        app:cornerRadius="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="从错题本截图或题目页面截图，自动OCR识别题目和答案"
        android:textColor="#999999"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- 悬浮窗开关 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="悬浮窗搜索"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="在答题界面输入关键词即可搜索答案"
                    android:textColor="#888888"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchFloating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- OCR识别状态提示 -->
    <TextView
        android:id="@+id/tvOcrStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text=""
        android:textColor="#666666"
        android:textSize="13sp"
        android:gravity="center" />

    <!-- 底部说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="auto"
        android:text="截图来源：学习强企错题本 / 每日一测页面\nOCR引擎：Google ML Kit（离线识别，无需联网）"
        android:textColor="#AAAAAA"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingBottom="16dp" />

</LinearLayout>
